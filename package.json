{
  "name": "shopsmart",
  "version": "1.0.0",
  "private": true,
  "description": "ShopSmart full-stack DevOps project (frontend + backend monorepo)",
  "scripts": {
    "prepare": "husky",
    "lint": "npm run lint --prefix client && npm run lint --prefix server",
    "format": "prettier --write \"**/*.{js,jsx,json,md,yml,yaml,css}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,json,md,yml,yaml,css}\"",
    "test": "npm test --prefix server && npm test --prefix client"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "client/**/*.{js,jsx,json,md,css}": [
      "prettier --write"
    ],
    "server/**/*.{js,json,md}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
